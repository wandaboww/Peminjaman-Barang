# SIM-Inventaris Configuration
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# DO NOT COMMIT .env TO GIT!

# ==========================================
# APPLICATION ENVIRONMENT
# ==========================================
APP_NAME=SIM-Inventaris
APP_ENV=production
APP_DEBUG=false
APP_URL=https://inventaris.sekolah.com

LOG_LEVEL=warning
LOG_CHANNEL=single

# ==========================================
# SECURITY - ADMIN CREDENTIALS (CHANGE THIS!)
# ==========================================
# For development only!
ADMIN_PASSWORD=change_me_to_secure_password_12345

# ==========================================
# DATABASE - PROTOTYPE (JSON)
# ==========================================
# For single-file prototype.php setup
DATABASE_FILE=database.json
ACTIVITY_LOG_FILE=activity_logs.json

# ==========================================
# DATABASE - LARAVEL (MySQL)
# ==========================================
# Uncomment and fill for Laravel deployment
# DB_CONNECTION=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_DATABASE=sim_inventaris
# DB_USERNAME=inventaris_user
# DB_PASSWORD=your_mysql_password_here
# DB_CHARSET=utf8mb4
# DB_COLLATION=utf8mb4_unicode_ci

# ==========================================
# SERVER CONFIGURATION
# ==========================================
DEV_SERVER_HOST=127.0.0.1
DEV_SERVER_PORT=8000

# ==========================================
# FEATURE FLAGS
# ==========================================
ENABLE_QR_GENERATION=true
ENABLE_BLACKLIST=true
STRICT_ONE_ITEM_POLICY=true

# ==========================================
# ROLE-BASED LOAN DURATION (in days)
# ==========================================
TEACHER_LOAN_DURATION=3
STUDENT_LOAN_DURATION=1

# ==========================================
# SESSION & SECURITY
# ==========================================
SESSION_TIMEOUT=3600
HTTPS_ONLY=false
CSRF_PROTECTION=true
