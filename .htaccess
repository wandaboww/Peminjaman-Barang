Options -Indexes

<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block hidden files except ACME / Let's Encrypt well-known paths.
    RewriteRule "(^|/)\.(?!well-known/)" - [F,L,NC]

    # Block direct access to sensitive application folders.
    RewriteRule "^(?:app|database|storage|\.git|\.github|\.vscode|\.venv)(?:/|$)" - [F,L,NC]

    # Block direct access to config, logs, docs, and SQLite artifacts.
    RewriteRule "^(?:\.env(?:\..*)?|composer\.(?:json|lock)|package(?:-lock)?\.json|yarn\.lock|database\.json|activity_logs\.json|.*\.(?:md|sql|log|bak|env|ini|sqlite|sqlite3|sqlite-journal|sqlite-wal|sqlite-shm))$" - [F,L,NC]
</IfModule>
