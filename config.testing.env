# SIM-Inventaris - Testing Port Configuration
# Gunakan file ini untuk mengatur port testing

# Prototype Server
PROTOTYPE_HOST=127.0.0.1
PROTOTYPE_PORT=8000

# Laravel Server (jika digunakan)
LARAVEL_HOST=127.0.0.1
LARAVEL_PORT=8001

# Database Testing
DB_FILE=database.json
DB_LOGS=activity_logs.json

# Admin Credentials (Testing Only - GANTI DI PRODUCTION!)
ADMIN_PASSWORD=admin123

# Testing URLs
PROTOTYPE_URL=http://127.0.0.1:8000
LARAVEL_URL=http://127.0.0.1:8001

# Notes:
# - Port 8000: Prototype (Single-file PHP dengan JSON database)
# - Port 8001: Laravel (Full MVC dengan MySQL)
# - Gunakan run-local-server.bat untuk prototype saja
# - Gunakan run-dual-servers.bat untuk keduanya sekaligus
